# ── Copy this file to .env and fill in your values ──────────

# MongoDB Connection
# Local:   mongodb://localhost:27017/eventmanagement
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/eventmanagement
MONGO_URI=mongodb://localhost:27017/eventmanagement

# JWT Secret (change this to something long and random in production)
JWT_SECRET=your_super_secret_jwt_key_change_this

# JWT Expiry
JWT_EXPIRES_IN=7d

# Server Port
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Email (SMTP) — use Gmail App Password or Ethereal for testing
# Ethereal test account: https://ethereal.email/create
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=no-reply@eventhub.com
